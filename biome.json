{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": { "ignoreUnknown": true, "includes": ["src/**/*.ts", "tests/**/*.ts", "*.config.ts"] },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" },
      "style": { "noNonNullAssertion": "error" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  }
}
