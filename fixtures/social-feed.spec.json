{
  "schema": "mobile-tui/1",
  "screens": [
    {
      "id": "feed",
      "title": "Feed",
      "kind": "regular",
      "acceptance": [
        "User sees a scrollable feed of posts with images",
        "User likes a post via the heart icon",
        "User opens the compose sheet to write a comment"
      ],
      "variants": {
        "content": {
          "kind": "content",
          "tree": [
            {
              "kind": "NavBar",
              "title": "Feed",
              "trailing": {
                "kind": "Button",
                "label": "New",
                "action": "open_composer",
                "testID": "compose_btn",
                "variant": "primary"
              }
            },
            {
              "kind": "List",
              "bindsTo": "/Post/text",
              "itemTemplate": {
                "kind": "ListItem",
                "label": "Open Post",
                "action": "open_post",
                "testID": "post_row",
                "children": [
                  {
                    "kind": "Card",
                    "child": {
                      "kind": "Column",
                      "gap": "sm",
                      "children": [
                        { "kind": "Image", "source": "/Post/text", "alt": "Post image" },
                        { "kind": "Text", "text": "Post content", "style": "body" },
                        {
                          "kind": "Row",
                          "gap": "sm",
                          "children": [
                            { "kind": "Icon", "name": "heart" },
                            {
                              "kind": "Button",
                              "label": "Like",
                              "action": "like_post",
                              "testID": "like_btn",
                              "variant": "text"
                            },
                            {
                              "kind": "Button",
                              "label": "Share",
                              "action": "share_post",
                              "testID": "share_btn",
                              "variant": "text"
                            }
                          ]
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        },
        "empty": {
          "kind": "empty",
          "when": { "collection": "/Post/text" },
          "tree": [
            { "kind": "Text", "text": "No posts yet. Be the first to share.", "style": "body" }
          ]
        },
        "loading": null,
        "error": null
      }
    },
    {
      "id": "post_detail",
      "title": "Post Detail",
      "kind": "regular",
      "back_behavior": "pop",
      "variants": {
        "content": {
          "kind": "content",
          "tree": [
            {
              "kind": "NavBar",
              "title": "Post Detail",
              "leading": {
                "kind": "Button",
                "label": "Back",
                "action": "open_post",
                "testID": "back_btn",
                "variant": "text"
              }
            },
            {
              "kind": "Card",
              "child": {
                "kind": "Column",
                "gap": "md",
                "children": [
                  { "kind": "Image", "source": "/Post/text", "alt": "Post image" },
                  { "kind": "Text", "text": "Post body text", "style": "body" },
                  { "kind": "Icon", "name": "heart-filled" },
                  {
                    "kind": "Button",
                    "label": "Submit comment",
                    "action": "submit_comment",
                    "testID": "submit_comment_btn",
                    "variant": "primary"
                  }
                ]
              }
            }
          ]
        },
        "empty": null,
        "loading": null,
        "error": null
      }
    },
    {
      "id": "compose_sheet",
      "title": "Compose",
      "kind": "overlay",
      "back_behavior": "dismiss",
      "variants": {
        "content": {
          "kind": "content",
          "tree": [
            {
              "kind": "Sheet",
              "child": {
                "kind": "Column",
                "gap": "md",
                "children": [
                  { "kind": "NavBar", "title": "New Post" },
                  {
                    "kind": "TextField",
                    "label": "Post text",
                    "action": "submit_comment",
                    "testID": "compose_field",
                    "bindsTo": "/Post/text",
                    "placeholder": "What's happening?"
                  },
                  {
                    "kind": "Button",
                    "label": "Post",
                    "action": "submit_comment",
                    "testID": "compose_post_btn",
                    "variant": "primary"
                  }
                ]
              }
            }
          ]
        },
        "empty": null,
        "loading": null,
        "error": null
      }
    }
  ],
  "actions": {
    "open_post": {
      "kind": "navigate",
      "screen": "post_detail",
      "params": { "post_id": "/Post/text" }
    },
    "open_composer": { "kind": "present", "overlay": "compose_sheet" },
    "like_post": { "kind": "mutate", "target": "/Post/liked", "op": "set", "value": true },
    "submit_comment": { "kind": "submit", "entity": "Post" },
    "share_post": {
      "kind": "custom",
      "name": "share_external",
      "description": "Hand the post URL to the OS share sheet"
    }
  },
  "data": {
    "entities": [
      {
        "name": "Post",
        "fields": [
          { "name": "text", "type": "string", "required": true },
          { "name": "liked", "type": "boolean" },
          { "name": "author", "type": "reference", "of": "Author" }
        ]
      },
      {
        "name": "Author",
        "fields": [
          { "name": "handle", "type": "string", "required": true },
          { "name": "avatar_url", "type": "string" }
        ]
      }
    ]
  },
  "navigation": {
    "root": "feed",
    "edges": [
      { "from": "feed", "to": "post_detail", "trigger": "open_post", "transition": "push" },
      { "from": "feed", "to": "compose_sheet", "trigger": "open_composer", "transition": "sheet" },
      { "from": "post_detail", "to": "feed", "trigger": "open_post", "transition": "replace" }
    ]
  }
}
